# === Server Configuration ===
APP_PORT=8080
APP_ENV=local

# === Database Configuration ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tene_life
DB_USERNAME=root
DB_PASSWORD=

# === Image & Weather Data (FTP Paths) ===
# Sem tvůj FTP skript ukládá data
WEATHER_JSON_PATH=public/files/weather.json
WEBCAM_IMAGE_PATH=public/images/tenelife.jpg

# === Camera Credentials (pro budoucí použití) ===
CAMERA_USERNAME=camera_axis+
CAMERA_PASSWORD=

# === Google Analytics (enabled only in production) ===
GA_MEASUREMENT_ID=

# === Tide Data (optional) ===
# WorldTides API key: https://www.worldtides.info/apidocs
TIDE_API_KEY=
TIDE_LAT=28.0436
TIDE_LON=-16.7215
TIDE_TIMEZONE=Atlantic/Canary

# === Official Bathing Water Quality (optional) ===
# IDECanarias WMS "Zonas de aguas de baño y Puntos de muestreo"
WATER_LAT=28.043493664088118
WATER_LON=-16.710318262067073
# Query window half-size in degrees used for GetFeatureInfo around WATER_LAT/LON
WATER_BBOX_RADIUS=0.08
# Prefer a PM record whose denomination contains this text
WATER_NAME_FILTER=CRISTIANOS
# Optional custom cache file
WATER_JSON_PATH=data/water_quality_latest.json
# In-app collectors (no Linux cron required)
WAVES_COLLECT_INTERVAL_MINUTES=15
WATER_COLLECT_INTERVAL_MINUTES=1440

# === The Weather Company PWS (optional) ===
WEATHER_COM_API_KEY=
PWS_COLLECT_INTERVAL_MINUTES=10
