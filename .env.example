# === Server Configuration ===
APP_PORT=8080
APP_ENV=local

# === Database Configuration ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tene_life
DB_USERNAME=root
DB_PASSWORD=

# === Image & Weather Data (FTP Paths) ===
# Sem tvůj FTP skript ukládá data
WEATHER_JSON_PATH=public/files/weather.json
WEBCAM_IMAGE_PATH=public/images/tenelife.jpg

# === Camera Credentials (pro budoucí použití) ===
CAMERA_USERNAME=camera_axis+
CAMERA_PASSWORD=

# === Google Analytics (enabled only in production) ===
GA_MEASUREMENT_ID=

# === Tide Data (optional) ===
# WorldTides API key: https://www.worldtides.info/apidocs
TIDE_API_KEY=
TIDE_LAT=28.0436
TIDE_LON=-16.7215
TIDE_TIMEZONE=Atlantic/Canary
